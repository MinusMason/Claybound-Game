@article{stomakhin_material_2013,
	title = {A material point method for snow simulation},
	volume = {32},
	issn = {0730-0301},
	url = {https://dl.acm.org/doi/10.1145/2461912.2461948},
	doi = {10.1145/2461912.2461948},
	abstract = {Snow is a challenging natural phenomenon to visually simulate. While the graphics community has previously considered accumulation and rendering of snow, animation of snow dynamics has not been fully addressed. Additionally, existing techniques for solids and fluids have difficulty producing convincing snow results. Specifically, wet or dense snow that has both solid- and fluid-like properties is difficult to handle. Consequently, this paper presents a novel snow simulation method utilizing a user-controllable elasto-plastic constitutive model integrated with a hybrid Eulerian/Lagrangian Material Point Method. The method is continuum based and its hybrid nature allows us to use a regular Cartesian grid to automate treatment of self-collision and fracture. It also naturally allows us to derive a grid-based semi-implicit integration scheme that has conditioning independent of the number of Lagrangian particles. We demonstrate the power of our method with a variety of snow phenomena including complex character interactions.},
	number = {4},
	urldate = {2025-10-27},
	journal = {ACM Trans. Graph.},
	author = {Stomakhin, Alexey and Schroeder, Craig and Chai, Lawrence and Teran, Joseph and Selle, Andrew},
	month = jul,
	year = {2013},
	pages = {102:1--102:10},
	file = {Full Text PDF:/Users/masonbuckle/Zotero/storage/XMRHB9P6/Stomakhin et al. - 2013 - A material point method for snow simulation.pdf:application/pdf},
}

@article{zhu_animating_2005,
	title = {Animating sand as a fluid},
	volume = {24},
	issn = {0730-0301},
	url = {https://dl.acm.org/doi/10.1145/1073204.1073298},
	doi = {10.1145/1073204.1073298},
	abstract = {We present a physics-based simulation method for animating sand. To allow for efficiently scaling up to large volumes of sand, we abstract away the individual grains and think of the sand as a continuum. In particular we show that an existing water simulator can be turned into a sand simulator with only a few small additions to account for inter-grain and boundary friction.We also propose an alternative method for simulating fluids. Our core representation is a cloud of particles, which allows for accurate and flexible surface tracking and advection, but we use an auxiliary grid to efficiently enforce boundary conditions and incompressibility. We further address the issue of reconstructing a surface from particle data to render each frame.},
	number = {3},
	urldate = {2025-10-27},
	journal = {ACM Trans. Graph.},
	author = {Zhu, Yongning and Bridson, Robert},
	month = jul,
	year = {2005},
	pages = {965--972},
	file = {Full Text PDF:/Users/masonbuckle/Zotero/storage/HUXJTLPZ/Zhu and Bridson - 2005 - Animating sand as a fluid.pdf:application/pdf},
}
@article{wang_physics-based_2024,
	title = {Physics-based fluid simulation in computer graphics: {Survey}, research trends, and challenges},
	volume = {10},
	issn = {2096-0662},
	shorttitle = {Physics-based fluid simulation in computer graphics},
	url = {https://ieeexplore.ieee.org/document/10885003},
	doi = {10.1007/s41095-023-0368-y},
	abstract = {Physics-based fluid simulation has played an increasingly important role in the computer graphics community. Recent methods in this area have greatly improved the generation of complex visual effects and its computational efficiency. Novel techniques have emerged to deal with complex boundaries, multiphase fluids, gas-liquid interfaces, and fine details. The parallel use of machine learning, image processing, and fluid control technologies has brought many interesting and novel research perspectives. In this survey, we provide an introduction to theoretical concepts underpinning physics-based fluid simulation and their practical implementation, with the aim for it to serve as a guide for both newcomers and seasoned researchers to explore the field of physics-based fluid simulation, with a focus on developments in the last decade. Driven by the distribution of recent publications in the field, we structure our survey to cover physical background; discretization approaches; computational methods that address scalability; fluid interactions with other materials and interfaces; and methods for expressive aspects of surface detail and control. From a practical perspective, we give an overview of existing implementations available for the above methods.},
	number = {5},
	urldate = {2025-10-12},
	journal = {Computational Visual Media},
	author = {Wang, Xiaokun and Xu, Yanrui and Liu, Sinuo and Ren, Bo and Kosinka, Jirí and Telea, Alexandru C. and Wang, Jiamin and Song, Chongming and Chang, Jian and Li, Chenfeng and Zhang, Jian Jun and Ban, Xiaojuan},
	month = oct,
	year = {2024},
	keywords = {Computational modeling, computer graphics, Computer graphics, fluid coupling, fluid simulation, Fluids, Graphics, Market research, Mathematical models, Media, physical simulation, Surveys, Tensors, Vectors},
	pages = {803--858},
	file = {Full Text PDF:/Users/masonbuckle/Zotero/storage/4CCJIG8D/Wang et al. - 2024 - Physics-based fluid simulation in computer graphics Survey, research trends, and challenges.pdf:application/pdf},
}


@inproceedings{fedkiw_visual_2001,
	title = {Visual simulation of smoke},
	isbn = {978-1-58113-374-5},
	url = {https://dl.acm.org/doi/10.1145/383259.383260},
	doi = {10.1145/383259.383260},
	abstract = {In this paper, we propose a new approach to numerical smoke simulation for computer graphics applications. The method proposed here exploits physics unique to smoke in order to design a numerical method that is both fast and efﬁcient on the relatively coarse grids traditionally used in computer graphics applications (as compared to the much ﬁner grids used in the computational ﬂuid dynamics literature). We use the inviscid Euler equations in our model, since they are usually more appropriate for gas modeling and less computationally intensive than the viscous NavierStokes equations used by others. In addition, we introduce a physically consistent vorticity conﬁnement term to model the small scale rolling features characteristic of smoke that are absent on most coarse grid simulations. Our model also correctly handles the interaction of smoke with moving objects.},
	language = {en},
	urldate = {2025-10-30},
	booktitle = {Proceedings of the 28th annual conference on {Computer} graphics and interactive techniques},
	publisher = {ACM},
	author = {Fedkiw, Ronald and Stam, Jos and Jensen, Henrik Wann},
	month = aug,
	year = {2001},
	pages = {15--22},
	file = {PDF:/Users/masonbuckle/Zotero/storage/YJ88N4VZ/Fedkiw et al. - 2001 - Visual simulation of smoke.pdf:application/pdf},
}

@article{macklin_position_2013,
	title = {Position based fluids},
	volume = {32},
	issn = {0730-0301, 1557-7368},
	url = {https://dl.acm.org/doi/10.1145/2461912.2461984},
	doi = {10.1145/2461912.2461984},
	abstract = {In ﬂuid simulation, enforcing incompressibility is crucial for realism; it is also computationally expensive. Recent work has improved efﬁciency, but still requires time-steps that are impractical for real-time applications. In this work we present an iterative density solver integrated into the Position Based Dynamics framework (PBD). By formulating and solving a set of positional constraints that enforce constant density, our method allows similar incompressibility and convergence to modern smoothed particle hydrodynamic (SPH) solvers, but inherits the stability of the geometric, position based dynamics method, allowing large time steps suitable for real-time applications. We incorporate an artiﬁcial pressure term that improves particle distribution, creates surface tension, and lowers the neighborhood requirements of traditional SPH. Finally, we address the issue of energy loss by applying vorticity conﬁnement as a velocity post process.},
	language = {en},
	number = {4},
	urldate = {2025-10-30},
	journal = {ACM Transactions on Graphics},
	author = {Macklin, Miles and Müller, Matthias},
	month = jul,
	year = {2013},
	pages = {1--12},
	file = {PDF:/Users/masonbuckle/Zotero/storage/7BPYW9UF/Macklin and Müller - 2013 - Position based fluids.pdf:application/pdf},
}

